# =============================================================================
# IMPORTANT FOR RAILWAY (production)
# =============================================================================
# Do NOT paste "localhost" DATABASE_URL or NODE_ENV=development into Railway.
# Railway’s “Suggested variables” often reads this file — treat suggestions as hints only.
#
# On your WEB service → Variables:
#
#   DATABASE_URL
#     → “New variable” → “Variable reference” (or ${{ ... }})
#     → Source: your PostgreSQL service
#     → Key: DATABASE_URL  (or DATABASE_PRIVATE_URL for private networking)
#
#   SESSION_SECRET → required in production; use a long random value (e.g. openssl rand -hex 32)
#
#   NODE_ENV       → production
#
#   ADMIN_PASSWORD → manager login for /admin (quiz results). Set in Variables; do not commit real values.
#
#   Do NOT set DATABASE_SSL=false on managed Railway Postgres unless required.
#   Omit LISTEN_HOST unless you have a special bind requirement (default is 0.0.0.0).
#
#   Health: use GET /api/live as the deploy healthcheck (no DB). JSON includes version from package.json.
#
# =============================================================================
# LOCAL development only — copy to “.env” and fill in real values
# =============================================================================

DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/friendly_quiz
SESSION_SECRET=local-dev-only-replace-with-long-random-string
# Manager login for /admin (quiz results). Required in production with a strong value.
ADMIN_PASSWORD=change-me
NODE_ENV=development

# Reverse proxy: defaults to trust 1 hop when NODE_ENV=production (Railway, etc.), false in development.
# Set TRUST_PROXY=false if Node is exposed directly to the internet (spoofed X-Forwarded-For could weaken login rate limits).
# Set TRUST_PROXY=2 if you chain two trusted proxies.
# TRUST_PROXY=false

# --- Employee training hub (PIN gate for quizzes + AI assistant) ---
# Required in production. In development only, if unset, the server uses DEV_EMPLOYEE_PIN_FALLBACK in backend/lib/devDefaults.js (currently 3707).
# Brute-force limits (per IP) are fixed in code: backend/lib/securityConstants.js
EMPLOYEE_ACCESS_PIN=3707

# --- AI quote/order assistant (OpenAI) ---
# Set locally and on your host when you deploy. Omit to run quizzes only (assistant returns 503).
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# Max wait per assistant reply in ms (default 90000; clamped 20000–180000 in code).
# OPENAI_TIMEOUT_MS=90000

# Optional: local Postgres without TLS only
# DATABASE_SSL=false

# Optional override (default 0.0.0.0 in code)
# LISTEN_HOST=0.0.0.0

# Per-request socket timeout in ms (default 420000). Raise only if proxies cut off /api/chat first.
# Clamped 120000–900000 in code. headersTimeout is requestTimeout + 1000.
# HTTP_REQUEST_TIMEOUT_MS=420000

# --- Quiz result emails (optional; omit to skip sending mail) ---
# Recipients default to customerservice@friendlypartyrental.com if unset.
# RESULTS_EMAIL_TO=customerservice@friendlypartyrental.com
# EMAIL_FROM="Friendly Quiz <noreply@yourdomain.com>"
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
