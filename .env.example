# Railway: reference Postgres DATABASE_URL (or DATABASE_PRIVATE_URL) on your web service — do not rely on Postgres-only variables unless referenced.
DATABASE_URL=postgresql://user:password@localhost:5432/friendly_quiz
# Set to false for local Postgres without TLS (optional; localhost/127.0.0.1 skip SSL automatically)
# DATABASE_SSL=false
ADMIN_PASSWORD=FriendlyAdmin2024
SESSION_SECRET=change-this-to-a-long-random-string
NODE_ENV=development
# Server bind address (default 0.0.0.0 — required on Railway)
# LISTEN_HOST=0.0.0.0
